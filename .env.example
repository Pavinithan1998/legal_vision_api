# LegalVision API Environment Variables
# Copy this file to .env and fill in your values

# Neo4j Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=your_neo4j_password

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key

# API Settings (optional)
HOST=0.0.0.0
PORT=8000
DEBUG=true
